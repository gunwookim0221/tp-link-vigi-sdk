# TP-Link VIGI SDK local integration test environment
# Copy this file to .env and replace placeholder values locally.
# Never commit .env.

# NVR OpenAPI integration test
VIGI_HOST=192.168.1.100
VIGI_PORT=20443
VIGI_USERNAME=admin
VIGI_PASSWORD=replace-with-nvr-password
VIGI_VERIFY_SSL=false

# IPC / standalone camera OpenAPI integration test
VIGI_IPC_HOST=192.168.1.213
VIGI_IPC_PORT=20443
VIGI_IPC_USERNAME=admin
VIGI_IPC_PASSWORD=replace-with-camera-password
VIGI_IPC_VERIFY_TLS=false

# Optional device metadata for local records only
VIGI_IPC_DEVICE_MODEL=VIGI C340I
VIGI_IPC_HARDWARE_VERSION=VIGI C340I 1.20
VIGI_IPC_FIRMWARE_VERSION=2.2.0 Build 250926 Rel.53599n
